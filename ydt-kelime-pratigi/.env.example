# Satın alım / kurumsal iletişim e-postası (fiyatlandırma sayfası + plan modalındaki "iletişim" kutusu).
# Boş bırakılırsa varsayılan: wordboost.team@gmail.com
# VITE_SALES_EMAIL=destek@wordboost.com.tr
# Alternatif anahtar: VITE_CONTACT_EMAIL

# Canlı site: https://wordboost.com.tr/ (Vercel custom domain + Railway API)
# --- İstemci (Vite build’e gömülür; Vercel’de Production + Preview için tanımla) ---
# Ödeme: manual = Paddle UI kapalı, premium yalnızca admin panelinden | paddle = Paddle checkout (VITE_PADDLE_CLIENT_TOKEN gerekir)
# VITE_BILLING_MODE=manual
# Socket.io: aynı Railway kök URL. Google girişi artık aynı origin /api/auth/* ile (VITE zorunlu değil).
# REST + Socket: production’da Railway kökü (profil, kelimeler, AI stream — Vercel /api 404 ise zorunlu)
VITE_SOCKET_URL=
# İsteğe bağlı; boşsa VITE_SOCKET_URL kullanılır: VITE_BACKEND_URL=https://xxx.railway.app

# --- Sadece Vercel sunucu tarafı (Build’e gömülmez; Vercel → Environment Variables) ---
# api/[...path] proxy: Express’in kök URL’i, sonunda / olmadan. Yerelde kullanılmaz.
# BACKEND_URL=https://xxx.railway.app

# Google AdSense publisher id (ör. ca-pub-6801396175139272). Build’e gömülür — Railway’de frontend Variables.
VITE_ADSENSE_CLIENT=
# AdSense birim ID’leri (sayısal)
VITE_ADSENSE_SLOT_DASHBOARD_SIDEBAR=
VITE_ADSENSE_SLOT_DASHBOARD_INLINE=

# Paddle.js client-side token (live_... veya test_...). Backend’deki PADDLE_API_KEY ile aynı ortam (sandbox/live) olmalı.
VITE_PADDLE_CLIENT_TOKEN=
