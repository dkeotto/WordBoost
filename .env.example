# Ornek: bu dosyayi .env olarak KOPYALA ve degerleri doldur.
# .env ASLA git'e commit edilmez (.gitignore). Gercek anahtarlar sadece Railway Variables.

PORT=3000
MONGO_URI=mongodb+srv://USER:PASS@cluster/dbname
SESSION_SECRET=uzun-rastgele-string

# Yerel: aşağıdaki gibi. Üretim (Railway): https://wordboost.com.tr (sonunda / yok)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# İsteğe bağlı: Google "Authorized redirect URIs" ile BİREBİR aynı olmalı. Boşsa sunucu şunu üretir:
# - FRONTEND_URL = https://wordboost.com.tr → redirect_uri = https://wordboost.com.tr/api/auth/google/callback
# - (dikkat: /api/auth/... — /auth/google/callback değil)
# - FRONTEND_URL lokal / Railway kök ise → BACKEND_URL/auth/google/callback
# Hata 400 redirect_uri_mismatch → Google Console’a tam bu URI’yi ekle; www ile açıyorsan www’li sürümü de ekle.
# GOOGLE_CALLBACK_URL=

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=WordBoost <noreply@example.com>
MAIL_FORCE_SMTP=false

BREVO_API_KEY=
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=WordBoost

# RESEND_API_KEY=
# RESEND_FROM=WordBoost <noreply@domain.com>

# Yönetim paneli: web girişi (ADMIN_USERNAME / ADMIN_PASSWORD) + API koruması.
# ADMIN_SECRET (≥12 karakter): admin JWT imzası ve isteğe bağlı X-Admin-Key. Boşsa JWT_SECRET kullanılır (prod’da ikisini de güçlü tut).
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=güçlü-bir-şifre
# ADMIN_SECRET=

# JWT secret (prod'da zorunlu, uzun rastgele string)
JWT_SECRET=

# Paddle (abonelik/premium). Uretim: PADDLE_ENV=live + API key; degerler yalnizca Variables / yerel .env
PADDLE_WEBHOOK_SECRET=
PADDLE_ENV=sandbox
PADDLE_API_KEY=
# Tier/price mapping: tek satır JSON (okunaklı şablon: paddle-price-ids.sample.json). Railway’e aynı string.
# Her tier’da isteğe bağlı displayPrice (kartlarda gösterilen fiyat metni, örn. "₺299 / ay" veya "Teklif için iletişim").
# Tier anahtarları: aiPlus (tek seferlik AI), premium (abonelik), classroom (okul, allowQuantity).
PADDLE_PRICE_IDS=

# AI sağlayıcı: AI_PROVIDER=groq | anthropic | ai_gateway (boşta: GROQ varsa Groq; yoksa gateway; yoksa Anthropic).
# Groq: console.groq.com → API Keys (ücretsiz katman hızlı; model listesi Groq dokümantasyonunda).
AI_PROVIDER=
GROQ_API_KEY=
# Örnek: llama-3.3-70b-versatile, llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile

# Vercel AI Gateway (vck_...): GROQ ile birlikte tanımlıysa otomatik yedekleme (429’da diğer uç).
# AI_FAILOVER=0 veya false → yalnız Groq. AI_FAILOVER_PRIMARY=groq | ai_gateway (varsayılan groq).
AI_GATEWAY_API_KEY=
# VERCEL_AI_GATEWAY_API_KEY=  (AI_GATEWAY_API_KEY ile aynı; isteğe bağlı yedek isim)
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
AI_GATEWAY_MODEL=openai/gpt-4o-mini
# AI_FAILOVER=
# AI_FAILOVER_PRIMARY=groq

# Anthropic (AI_PROVIDER=anthropic veya Groq anahtarı yoksa). sk-ant- ile baslar.
# AI Sohbet + uzun yanıtlar için Claude (Sonnet ve üzeri) önerilir; Groq hızlıdır, üslup farkı olabilir.
ANTHROPIC_API_KEY=
# Tarihli ID; *-latest not_found verebiliyor
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Classroom
# (DB’de otomatik code üretilir, ekstra ayar gerekmiyor)

# --- Vercel (yalnızca frontend deploy; backend bu dosyayı kullanmaz) ---
# Vercel Project env: BACKEND_URL = Railway Express kök URL (proxy). İstemci env: ydt-kelime-pratigi/.env.example
