# Ornek: bu dosyayi .env olarak KOPYALA ve degerleri doldur.
# .env ASLA git'e commit edilmez (.gitignore). Gercek anahtarlar sadece Railway Variables.

PORT=3000
MONGO_URI=mongodb+srv://USER:PASS@cluster/dbname
SESSION_SECRET=uzun-rastgele-string

FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=WordBoost <noreply@example.com>
MAIL_FORCE_SMTP=false

BREVO_API_KEY=
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=WordBoost

# RESEND_API_KEY=
# RESEND_FROM=WordBoost <noreply@domain.com>

# Yönetim paneli (/api/admin/* ve "Yönetim" sekmesi). Min 12 karakter, rastgele uzun string.
# ADMIN_SECRET=

# JWT secret (prod'da zorunlu, uzun rastgele string)
JWT_SECRET=

# Paddle (abonelik/premium)
PADDLE_WEBHOOK_SECRET=
PADDLE_ENV=sandbox
PADDLE_API_KEY=
# Tier/price mapping (JSON). Örnek:
# PADDLE_PRICE_IDS={"premium":{"priceId":"pri_xxx","label":"Premium","description":"Bireysel premium","features":["AI Mode sınırsız"],"entitlements":{"premium":true}},"school":{"priceId":"pri_yyy","label":"School","description":"Okul lisansı","allowQuantity":true,"defaultQuantity":30,"features":["Sınıf paneli","Toplu hesap"],"entitlements":{"schoolLicense":true,"premium":true}}}
PADDLE_PRICE_IDS=

# Anthropic (AI Mode)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Classroom
# (DB’de otomatik code üretilir, ekstra ayar gerekmiyor)
